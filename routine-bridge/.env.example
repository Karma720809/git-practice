# routine-bridge 설정 예시 — 이 파일을 .env 로 복사한 뒤 값 채우기.
# 실제 .env 는 절대 커밋하지 마세요 (.gitignore 에 포함됨).

# claude.ai/code/routines 에서 API 트리거 추가 시 발급되는 /fire URL (필수)
ROUTINE_FIRE_URL=https://api.anthropic.com/v1/claude_code/routines/trig_여기에ID/fire

# 같은 화면에서 발급되는 bearer 토큰 (필수, 한 번만 표시됨)
ROUTINE_BEARER_TOKEN=sk-ant-oat01-여기에토큰

# 답변을 읽어올 GitHub 메일박스 이슈에 read 권한이 있는 토큰 (필수)
GITHUB_TOKEN=ghp_여기에토큰

# 메일박스 이슈 위치 (선택, 기본값 karma720809/git-practice)
GITHUB_OWNER=karma720809
GITHUB_REPO=git-practice

# 메일박스로 쓸 이슈 번호 (필수)
MAILBOX_ISSUE_NUMBER=2

# 답글 대기 최대 시간(초) / 폴링 주기(초) (선택)
# Routine 은 Slack 멘션보다 느릴 수 있어 기본 타임아웃을 더 길게 잡음.
REPLY_TIMEOUT_SEC=600
POLL_INTERVAL_SEC=5
