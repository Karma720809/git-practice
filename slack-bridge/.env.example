# slack-bridge 설정 예시 — 이 파일을 .env 로 복사한 뒤 값 채우기.
# 실제 .env 는 절대 커밋하지 마세요 (.gitignore 에 포함됨).

# 브릿지 봇의 Bot User OAuth Token (필수)
SLACK_BOT_TOKEN=xoxb-여기에-토큰

# 자료를 올릴 공용 채널 ID (필수). 예: C0123ABCD
BRIDGE_CHANNEL_ID=C0000000000

# 멘션 대상 Slack Claude user id (선택, 기본값 U0B6TG36A3Z)
CLAUDE_USER_ID=U0B6TG36A3Z

# 답글 대기 최대 시간(초) / 폴링 주기(초) (선택)
REPLY_TIMEOUT_SEC=180
POLL_INTERVAL_SEC=3
